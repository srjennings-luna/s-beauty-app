# Fastlane Fastfile for Contueri iOS build + TestFlight deployment.
#
# Activated by the .github/workflows/ios-build.yml GitHub Actions
# pipeline. Two lanes:
#
#   match_init      One-time setup. Run locally (NOT in CI) the first
#                   time, after Apple Developer enrollment activates,
#                   to generate the distribution certificate and
#                   provisioning profile and push them to the
#                   encrypted MATCH_GIT_URL repo. Required before
#                   the CI pipeline can succeed.
#
#   deploy_testflight   The CI lane. Pulls certs via Match (read-only),
#                       bumps the build number, archives the
#                       Capacitor-generated Xcode scheme, signs, and
#                       uploads to TestFlight via App Store Connect
#                       API key.
#
# Local prerequisites (W1 manual setup, one-time):
#
#   1. Apple Developer Individual enrollment active.
#   2. App ID registered in Apple Developer portal:
#        Bundle ID: app.contueri.ios
#        Capabilities: Push Notifications, Background Modes (audio)
#   3. App Store Connect API key generated and downloaded as .p8 file.
#      Save the file content as APP_STORE_CONNECT_API_KEY_CONTENT
#      secret in GitHub Actions.
#   4. Empty private GitHub repo created for cert storage. Set its
#      URL as MATCH_GIT_URL secret.
#   5. Run `bundle exec fastlane match_init` locally ONCE after the
#      above are in place. This populates the cert repo with the
#      encrypted certificate and profile.
#   6. From this point forward, every push to main triggers the CI
#      pipeline which uses match in --readonly mode.

default_platform(:ios)

# Path to the Xcode project generated by Capacitor (`npx cap add ios`).
# Capacitor 8 uses Swift Package Manager for native plugins (CapApp-SPM)
# rather than CocoaPods, so there is NO `App.xcworkspace` at the top
# level — just `App.xcodeproj`. Fastlane's build_app action accepts
# `project:` directly when there is no workspace.
PROJECT_PATH   = "ios/App/App.xcodeproj"
SCHEME         = "App"

platform :ios do
  desc "One-time match init. Generates distribution cert + profile and pushes encrypted to MATCH_GIT_URL."
  lane :match_init do
    # Without --readonly, match will CREATE certs and profiles if they
    # do not exist. Run this lane LOCALLY (not in CI) after Apple
    # Developer enrollment activates.
    match(
      type: "appstore",
      app_identifier: ["app.contueri.ios"],
      readonly: false,
      force: false,
    )
  end

  desc "CI: pull certs, bump build number, archive, sign, upload to TestFlight."
  lane :deploy_testflight do
    # Pull existing certs without creating new ones. Fails fast in
    # CI if certs are missing; match_init must run locally first.
    match(
      type: "appstore",
      app_identifier: ["app.contueri.ios"],
      readonly: true,
    )

    # Switch the Xcode project from "Automatic signing" (the Xcode
    # default that requires GUI sign-in) to manual signing using the
    # Match-installed AppStore profile. Without this, `xcodebuild
    # archive` in CI fails with "No profiles for 'app.contueri.ios'
    # were found" because there's no Xcode GUI to grant signing
    # access. Match sets ENV vars after running with the profile
    # name and team id; we read those to configure the project.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: PROJECT_PATH,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "app.contueri.ios",
      profile_name: ENV["sigh_app.contueri.ios_appstore_profile-name"] || "match AppStore app.contueri.ios",
      build_configurations: ["Release"],
    )

    # Authenticate to App Store Connect with the API key (no Apple
    # ID password required for upload).
    app_store_connect_api_key(
      key_id:      ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:   ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      duration:    1200,
      in_house:    false,
    )

    # Bump the build number from the highest TestFlight build for
    # this app. Idempotent across re-runs of the same commit.
    increment_build_number(
      build_number: latest_testflight_build_number(
        app_identifier: "app.contueri.ios",
      ) + 1,
      xcodeproj: PROJECT_PATH,
    )

    # Archive and sign the Capacitor iOS project (Capacitor 8 + SPM —
    # no workspace, use project directly).
    build_app(
      project:          PROJECT_PATH,
      scheme:           SCHEME,
      export_method:    "app-store",
      output_directory: "ios/build",
      output_name:      "Contueri.ipa",
      clean:            true,
      include_bitcode:  false,
      include_symbols:  true,
    )

    # Upload to TestFlight. No external testers added automatically;
    # internal cohort (Sheri + invited beta testers) gets the build
    # immediately. External submission happens manually in App Store
    # Connect once the build clears internal review.
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Latest changes from main. See git history for detail.",
    )
  end
end
