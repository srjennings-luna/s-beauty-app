# Pinned Ruby dependencies for Fastlane iOS build pipeline.
#
# Used by .github/workflows/ios-build.yml on macOS runners and by
# Sheri locally for the one-time `fastlane match_init` step.
#
# Run `bundle install` to install. Run `bundle update fastlane` to
# pull a newer Fastlane release; commit the resulting Gemfile.lock.

source "https://rubygems.org"

gem "fastlane", "~> 2.224"
